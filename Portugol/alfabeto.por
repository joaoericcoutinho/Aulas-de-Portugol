programa {
  funcao inicio() {
    cadeia letra
    

    escreva("Digite uma letra de a - z: ")
    leia(letra)

    escolha(letra){
      caso "a":
      caso "e":
      caso "i":
      caso "o":
      caso "u":
      escreva("Digitol uma vogal")
      pare
      
      caso contrario:
      escreva("Você digitol uma consoante")
      
    }



    
  }
}
