programa {
  funcao inicio() {

    cadeia nome[7]
    inteiro i

    para(i = 0; i < 7; i++){
      escreva("Digite o ", i+1, "º número: ")
      leia(nome[i])
    }

      escreva("Os nomes são:", "\n")
      para(inteiro i = 0; i < 15; i++){
      escreva(nome[i], "\n")
      }
    
      }

    }
