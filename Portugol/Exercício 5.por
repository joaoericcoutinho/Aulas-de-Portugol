programa {
  funcao inicio() {
   
    inteiro n1, n2
    inteiro soma, sub, mult
    real div
   
    escreva("Digite o primeiro número: ")
    leia(n1)
   
    escreva("Digite o segundo número: ")
    leia(n2)
   
   soma = n1 + n2
   sub = n1 - n2
   mult = n1 * n2
   div = n1 / n2

    escreva("\nResultados:\n")
    escreva("Soma: ", soma, "\n")
    escreva("Subtração: ", sub, "\n")
    escreva("Multiplicação: ", mult, "\n")
    escreva("Divisão: ", div)
    
  
   
  }

}