programa {
  funcao inicio() {
   
    inteiro n1, n2
    inteiro sub
   
    escreva("Digite o ano que a pessoa morreu: ")
    leia(n1)
   
    escreva("Digite o ano que a pessoa naceu: ")
    leia(n2)
   

   sub = n1 - n2


    escreva("\nResultados:\n")
    escreva("Ficou vivo por: ", sub, "\n")

    
  
   
  }

}