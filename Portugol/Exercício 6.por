programa {
  funcao inicio() {
   
    inteiro n1
    cadeia numero, sucessor, antecessor

   
    escreva("Digite o primeiro número: ")
    leia(n1)
   
    n1
    n1 + 1
    n1 - 1
  
   escreva("\n Resultados:\n")
   escreva("numero: ", n1, "\n")
   escreva("sucessor:", n1 + 1,"\n")
   escreva("antecessor:", n1 - 1, "\n")
  }


}